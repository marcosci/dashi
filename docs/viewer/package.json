{
  "name": "dashi-viewer",
  "private": true,
  "version": "0.1.0",
  "description": "Pre-bundled deck.gl + loaders.gl viewer for dashi point clouds",
  "type": "module",
  "scripts": {
    "build": "esbuild src/entry.js --bundle --format=esm --target=es2020 --outfile=viewer.bundle.js --minify --legal-comments=none"
  },
  "dependencies": {
    "@deck.gl/core":       "^9.0.32",
    "@deck.gl/layers":     "^9.0.32",
    "@deck.gl/geo-layers": "^9.0.32",
    "@loaders.gl/core":    "^4.3.2",
    "@loaders.gl/las":     "^4.3.2",
    "@loaders.gl/3d-tiles":"^4.3.2",
    "copc":                "^0.0.8"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
