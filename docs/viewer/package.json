{
  "name": "dashi-viewer",
  "private": true,
  "version": "0.2.0",
  "description": "dashi point cloud viewer — wraps opengeos/maplibre-gl-lidar for COPC streaming over a MapLibre basemap",
  "type": "module",
  "scripts": {
    "build": "esbuild src/entry.js --bundle --format=esm --target=es2020 --outfile=viewer.bundle.js --minify --legal-comments=none --loader:.css=text"
  },
  "dependencies": {
    "maplibre-gl":       "^5.24.0",
    "maplibre-gl-lidar": "^0.11.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
