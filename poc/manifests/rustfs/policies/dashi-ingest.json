{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LandingZoneWrite",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectTagging",
        "s3:GetObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::landing",
        "arn:aws:s3:::landing/*"
      ]
    }
  ]
}
