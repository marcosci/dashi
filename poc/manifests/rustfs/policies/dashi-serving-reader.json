{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ProcessedZoneRead",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::processed",
        "arn:aws:s3:::processed/*"
      ]
    },
    {
      "Sid": "CuratedZoneRead",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::curated",
        "arn:aws:s3:::curated/*"
      ]
    }
  ]
}
